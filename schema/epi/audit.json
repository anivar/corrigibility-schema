{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:corrigibility:epi/audit.json",
  "title": "Corrigibility EPI Audit",
  "description": "Independent auditor assessment for Epistemic Public Infrastructure",
  "type": "object",
  "required": [
    "protocol_version",
    "system_id",
    "audit_id",
    "timestamp",
    "valid_until",
    "audited_manifest_version",
    "audited_manifest_hash",
    "results",
    "lwd_r_verification",
    "auditor",
    "auditor_signature"
  ],
  "properties": {
    "protocol_version": {
      "type": "string",
      "pattern": "^2\\.[0-9]+$"
    },
    "system_id": { "type": "string" },
    "audit_id": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "valid_until": {
      "type": "string",
      "format": "date-time",
      "description": "Audit expiration (max 12 months)"
    },
    "audited_manifest_version": { "type": "string" },
    "audited_manifest_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "verification_tier": {
      "type": "string",
      "enum": ["presence", "behavior", "proof"],
      "description": "Depth: presence (docs), behavior (tested), proof (formal)"
    },
    "results": {
      "type": "object",
      "required": ["EXIT", "CODE", "AUDIT", "GOVERN", "FORK"],
      "properties": {
        "EXIT": { "type": "boolean" },
        "CODE": { "type": "boolean" },
        "AUDIT": { "type": "boolean" },
        "GOVERN": { "type": "boolean" },
        "FORK": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "lwd_r_verification": {
      "type": "object",
      "required": ["logic_verified", "weights_verified", "data_verified", "representation_verified"],
      "properties": {
        "logic_verified": { "type": "boolean" },
        "weights_verified": { "type": "boolean" },
        "data_verified": { "type": "boolean" },
        "representation_verified": { "type": "boolean" },
        "lwd_r_complete": {
          "type": "boolean",
          "description": "All LWD-R verified (required for CODE=true)"
        }
      },
      "additionalProperties": false
    },
    "action_boundary_verification": {
      "type": "object",
      "properties": {
        "enforced": { "type": "boolean" },
        "mechanism_verified": {
          "type": "string",
          "enum": ["hard_coded", "policy_engine", "human_approval", "hybrid", "none"]
        },
        "escapes_found": { "type": "integer" },
        "escapes_documented": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "drift_assessment": {
      "type": "object",
      "properties": {
        "measured": { "type": "boolean" },
        "methodology": { "type": "string" },
        "baseline_date": { "type": "string", "format": "date" },
        "current_drift_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "retraining_trigger": { "type": "number" },
        "trend": {
          "type": "string",
          "enum": ["stable", "increasing", "decreasing"]
        }
      },
      "additionalProperties": false
    },
    "compute_verification": {
      "type": "object",
      "properties": {
        "inference_accessible": { "type": "boolean" },
        "training_accessible": { "type": "boolean" },
        "swap_tested": { "type": "boolean" },
        "swap_time_actual_minutes": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "governance_verification": {
      "type": "object",
      "properties": {
        "grievance_exists": { "type": "boolean" },
        "grievance_functional": { "type": "boolean" },
        "binding_mechanism_exists": { "type": "boolean" },
        "binding_mechanism_tested": { "type": "boolean" },
        "community_represented": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test", "finding", "severity"],
        "properties": {
          "test": {
            "type": "string",
            "enum": ["EXIT", "CODE", "AUDIT", "GOVERN", "FORK", "LWD_R", "DRIFT", "BOUNDARY", "TIER"]
          },
          "finding": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "observation"]
          }
        },
        "additionalProperties": false
      }
    },
    "tier_appropriate": {
      "type": "boolean",
      "description": "System meets declared tier requirements"
    },
    "delegated_verification": {
      "type": "object",
      "description": "Components verified by observatory body",
      "properties": {
        "observatory": { "type": "string" },
        "component_id": { "type": "string" },
        "certified_profile_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "certification_date": { "type": "string", "format": "date" },
        "certification_url": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "contestation": {
      "type": "object",
      "properties": {
        "contested": { "type": "boolean", "default": false },
        "filed_at": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["pending", "upheld", "overturned", "withdrawn"]
        },
        "resolution_date": { "type": ["string", "null"], "format": "date-time" },
        "resolution_summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "revocation": {
      "type": "object",
      "properties": {
        "revoked": { "type": "boolean", "default": false },
        "revoked_at": { "type": "string", "format": "date-time" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "auditor": {
      "type": "object",
      "required": ["entity", "public_key"],
      "properties": {
        "entity": { "type": "string" },
        "accreditation": { "type": "string" },
        "public_key": { "type": "string" }
      },
      "additionalProperties": false
    },
    "auditor_signature": { "type": "string" }
  },
  "additionalProperties": false
}
